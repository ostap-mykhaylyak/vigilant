#!/usr/bin/env php
<?php
/**
 * vigilant — Cloudflare auto Under Attack Mode
 *
 * Watches server load and/or per-zone request rate and toggles Cloudflare
 * Under Attack Mode (UAM) when thresholds are crossed. Built for CLI/cron.
 * Credentials are never passed as arguments (visible in `ps`/`/proc`); they
 * live in a chmod 600 config file.
 *
 * @package   vigilant
 * @author    Ostap Mykhaylyak
 * @license   MIT
 * @link      https://github.com/ostap-mykhaylyak/vigilant
 */

declare(strict_types=1);

const VIGILANT_VERSION = '1.0.0';

// Exit codes: 0=ok, 1=runtime error, 2=usage/config error.
const EXIT_OK      = 0;
const EXIT_RUNTIME = 1;
const EXIT_USAGE   = 2;

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "This script must be run from the CLI.\n");
    exit(EXIT_USAGE);
}

function printUsage(): void
{
    $name = basename($GLOBALS['argv'][0]);
    $ver  = VIGILANT_VERSION;
    echo <<<TXT
    vigilant v{$ver} — Cloudflare auto Under Attack Mode

    USAGE:
      php {$name} [options]

    OPTIONS:
      --config=PATH   Path to the config file (default: ./config.php)
      --status        Print current metrics and security level, then exit
      --force-on      Force Under Attack Mode on
      --force-off     Force the normal security level back
      -h, --help      Show this help
      -V, --version   Show the version

    With no options it runs one evaluation cycle (intended for cron).

    DOCS: https://github.com/ostap-mykhaylyak/vigilant

    TXT;
}

// ---------------------------------------------------------------------------
// Argument parsing
// ---------------------------------------------------------------------------
$opts = [
    'config'    => __DIR__ . '/config.php',
    'force-on'  => false,
    'force-off' => false,
    'status'    => false,
];

foreach (array_slice($argv, 1) as $arg) {
    if (str_starts_with($arg, '--config=')) {
        $opts['config'] = substr($arg, strlen('--config='));
    } elseif ($arg === '--force-on') {
        $opts['force-on'] = true;
    } elseif ($arg === '--force-off') {
        $opts['force-off'] = true;
    } elseif ($arg === '--status') {
        $opts['status'] = true;
    } elseif ($arg === '-h' || $arg === '--help') {
        printUsage();
        exit(EXIT_OK);
    } elseif ($arg === '-V' || $arg === '--version') {
        echo 'vigilant ' . VIGILANT_VERSION . "\n";
        exit(EXIT_OK);
    } else {
        fwrite(STDERR, "Unknown argument: {$arg}\n");
        fwrite(STDERR, "Use --help for the list of options.\n");
        exit(EXIT_USAGE);
    }
}

if ($opts['force-on'] && $opts['force-off']) {
    fwrite(STDERR, "Conflicting options: --force-on and --force-off.\n");
    exit(EXIT_USAGE);
}

// ---------------------------------------------------------------------------
// Load and validate config
// ---------------------------------------------------------------------------
$configPath = $opts['config'];

if (!is_file($configPath)) {
    fwrite(STDERR, "Config not found: {$configPath}\n");
    exit(EXIT_USAGE);
}

// The credentials file must not be readable/writable by other users.
$perms = fileperms($configPath) & 0o777;
if (($perms & 0o077) !== 0) {
    fwrite(STDERR, sprintf(
        "Insecure permissions on %s (%04o). Run: chmod 600 %s\n",
        $configPath, $perms, $configPath
    ));
    exit(EXIT_USAGE);
}

$config = require $configPath;

foreach (['api_token', 'zone_id'] as $key) {
    if (empty($config[$key])) {
        fwrite(STDERR, "Incomplete config: missing '{$key}'\n");
        exit(EXIT_USAGE);
    }
}

// Defaults.
$config += [
    // Trigger mode: 'load' | 'requests' | 'both'.
    'trigger_mode'       => 'load',

    // --- 'load' mode ---
    'cpu_cores'          => null,   // null = auto-detect
    'load_index'         => 0,      // 0=1min, 1=5min, 2=15min
    'threshold_on'       => 1.50,   // load-per-core to switch UAM on
    'threshold_off'      => 0.70,   // load-per-core to switch UAM off

    // --- 'requests' mode ---
    'req_threshold_on'   => 50.0,   // requests/sec to switch UAM on
    'req_threshold_off'  => 20.0,   // requests/sec to switch UAM off
    'req_window_minutes' => 5,      // averaging window

    // --- common ---
    'normal_level'       => 'medium', // off|essentially_off|low|medium|high
    'min_uam_seconds'    => 600,      // min dwell time before standing down
    'state_file'         => __DIR__ . '/vigilant-state.json',
    'log_file'           => null,     // null = stdout/stderr
    'http_timeout'       => 15,
];

// ---------------------------------------------------------------------------
// Logging
// ---------------------------------------------------------------------------
function logmsg(array $config, string $level, string $msg): void
{
    $line = sprintf('[%s] %-5s %s', date('Y-m-d H:i:s'), $level, $msg);
    if (!empty($config['log_file'])) {
        @file_put_contents($config['log_file'], $line . "\n", FILE_APPEND | LOCK_EX);
    } else {
        fwrite($level === 'ERROR' ? STDERR : STDOUT, $line . "\n");
    }
}

// ---------------------------------------------------------------------------
// Metrics
// ---------------------------------------------------------------------------
function detectCores(): int
{
    // Read /proc only; shell_exec/exec are usually disabled on shared hosting.
    if (@is_readable('/proc/cpuinfo')) {
        $content = @file_get_contents('/proc/cpuinfo');
        if ($content !== false) {
            $n = preg_match_all('/^processor\s*:/m', $content);
            if ($n > 0) {
                return $n;
            }
        }
    }
    return 1;
}

function getLoadAverages(): array
{
    // Prefer /proc/loadavg; sys_getloadavg() is sometimes in disable_functions.
    if (@is_readable('/proc/loadavg')) {
        $raw = @file_get_contents('/proc/loadavg');
        if ($raw !== false) {
            $parts = preg_split('/\s+/', trim($raw));
            if (count($parts) >= 3) {
                return [(float)$parts[0], (float)$parts[1], (float)$parts[2]];
            }
        }
    }
    if (function_exists('sys_getloadavg')) {
        $la = @sys_getloadavg();
        if (is_array($la) && count($la) === 3) {
            return $la;
        }
    }
    fwrite(STDERR, "Cannot read load average: neither /proc/loadavg nor " .
        "sys_getloadavg() is accessible. Consider trigger_mode 'requests'.\n");
    exit(EXIT_RUNTIME);
}

// ---------------------------------------------------------------------------
// State (anti-flapping)
// ---------------------------------------------------------------------------
function loadState(array $config): array
{
    if (is_file($config['state_file'])) {
        $data = json_decode((string)file_get_contents($config['state_file']), true);
        if (is_array($data)) {
            return $data;
        }
    }
    return ['uam_active' => false, 'changed_at' => 0];
}

function saveState(array $config, array $state): void
{
    @file_put_contents($config['state_file'], json_encode($state, JSON_PRETTY_PRINT), LOCK_EX);
}

// ---------------------------------------------------------------------------
// Cloudflare API
// ---------------------------------------------------------------------------
function cfRequestCurl(array $config, string $url, string $method, array $headers, ?string $payload): array
{
    $ch = curl_init($url);
    curl_setopt_array($ch, [
        CURLOPT_CUSTOMREQUEST  => $method,
        CURLOPT_HTTPHEADER     => $headers,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_TIMEOUT        => $config['http_timeout'],
        CURLOPT_CONNECTTIMEOUT => 10,
    ]);
    if ($payload !== null) {
        curl_setopt($ch, CURLOPT_POSTFIELDS, $payload);
    }
    $raw  = curl_exec($ch);
    $err  = curl_error($ch);
    $code = (int)curl_getinfo($ch, CURLINFO_HTTP_CODE);
    curl_close($ch);

    return [$raw === false ? null : $raw, $code, $err];
}

function cfRequestStream(array $config, string $url, string $method, array $headers, ?string $payload): array
{
    $ctx = stream_context_create(['http' => [
        'method'        => $method,
        'header'        => implode("\r\n", $headers),
        'content'       => $payload ?? '',
        'timeout'       => $config['http_timeout'],
        'ignore_errors' => true, // read the body on 4xx/5xx too
    ]]);

    $raw  = @file_get_contents($url, false, $ctx);
    $code = 0;
    if (isset($http_response_header[0]) &&
        preg_match('#\s(\d{3})\s#', $http_response_header[0], $m)) {
        $code = (int)$m[1];
    }
    $err = $raw === false ? 'HTTP stream request failed' : '';

    return [$raw === false ? null : $raw, $code, $err];
}

function cfRequest(array $config, string $method, string $path, ?array $body = null): array
{
    $url     = 'https://api.cloudflare.com/client/v4' . $path;
    $payload = $body !== null ? json_encode($body) : null;
    $headers = [
        'Authorization: Bearer ' . $config['api_token'],
        'Content-Type: application/json',
    ];

    // Prefer cURL; fall back to stream wrappers (often the only option on
    // shared hosting where cURL is disabled).
    if (function_exists('curl_init')) {
        [$raw, $code, $err] = cfRequestCurl($config, $url, $method, $headers, $payload);
    } elseif (ini_get('allow_url_fopen')) {
        [$raw, $code, $err] = cfRequestStream($config, $url, $method, $headers, $payload);
    } else {
        throw new RuntimeException(
            'Neither cURL nor allow_url_fopen is available: cannot reach the Cloudflare API.'
        );
    }

    if ($raw === false || $raw === null) {
        throw new RuntimeException("Network error: {$err}");
    }

    $data = json_decode($raw, true);
    if (!is_array($data)) {
        throw new RuntimeException("Invalid Cloudflare response (HTTP {$code}): {$raw}");
    }

    // The GraphQL endpoint returns {data,errors} instead of the REST
    // {success,...} envelope; let the caller handle GraphQL errors.
    if ($path === '/graphql') {
        if ($code >= 400) {
            throw new RuntimeException("GraphQL HTTP {$code}: {$raw}");
        }
        return $data;
    }

    if (empty($data['success'])) {
        $msg = isset($data['errors']) ? json_encode($data['errors']) : 'unknown error';
        throw new RuntimeException("Cloudflare API failed (HTTP {$code}): {$msg}");
    }

    return $data;
}

function getSecurityLevel(array $config): string
{
    $resp = cfRequest($config, 'GET', "/zones/{$config['zone_id']}/settings/security_level");
    return (string)($resp['result']['value'] ?? 'unknown');
}

function setSecurityLevel(array $config, string $level): void
{
    cfRequest($config, 'PATCH', "/zones/{$config['zone_id']}/settings/security_level", ['value' => $level]);
}

/**
 * Average requests/sec to the zone over the last N minutes.
 *
 * Uses httpRequestsAdaptiveGroups (available on all plans; httpRequests1mGroups
 * is Business/Enterprise only). That dataset is sampled, so the real count is
 * estimated as count * avg.sampleInterval. Requires Zone > Analytics > Read.
 */
function getRequestsPerSecond(array $config): float
{
    $minutes = max(1, (int)$config['req_window_minutes']);

    // Close the window one minute in the past to skip the incomplete minute.
    $end   = new DateTimeImmutable('-1 minute', new DateTimeZone('UTC'));
    $start = $end->sub(new DateInterval("PT{$minutes}M"));
    $fmt   = 'Y-m-d\TH:i:s\Z';

    $query = <<<'GQL'
    query ($zoneTag: String!, $start: Time!, $end: Time!) {
      viewer {
        zones(filter: { zoneTag: $zoneTag }) {
          httpRequestsAdaptiveGroups(
            limit: 1000
            filter: { datetime_geq: $start, datetime_lt: $end }
          ) {
            count
            avg { sampleInterval }
          }
        }
      }
    }
    GQL;

    $resp = cfRequest($config, 'POST', '/graphql', [
        'query'     => $query,
        'variables' => [
            'zoneTag' => $config['zone_id'],
            'start'   => $start->format($fmt),
            'end'     => $end->format($fmt),
        ],
    ]);

    // GraphQL can return HTTP 200 with application-level errors in the body.
    if (!empty($resp['errors'])) {
        throw new RuntimeException('GraphQL Analytics returned errors: ' . json_encode($resp['errors']));
    }

    $groups = $resp['data']['viewer']['zones'][0]['httpRequestsAdaptiveGroups'] ?? [];
    $total  = 0.0;
    foreach ($groups as $g) {
        $count    = (float)($g['count'] ?? 0);
        $interval = (float)($g['avg']['sampleInterval'] ?? 1);
        $total += $count * ($interval > 0 ? $interval : 1); // de-sample
    }

    return $total / ($minutes * 60);
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------
try {
    if ($opts['status']) {
        $level = getSecurityLevel($config);
        $cores = max(1, (int)($config['cpu_cores'] ?? detectCores()));
        $la    = getLoadAverages();
        printf(
            "Trigger mode        : %s\n" .
            "Security level      : %s\n" .
            "Load avg (1/5/15)   : %.2f / %.2f / %.2f\n" .
            "CPU cores           : %d\n" .
            "Load per core (1m)  : %.2f  (on>=%.2f / off<=%.2f)\n",
            $config['trigger_mode'], $level, $la[0], $la[1], $la[2], $cores,
            $la[0] / $cores, $config['threshold_on'], $config['threshold_off']
        );
        if ($config['trigger_mode'] === 'requests' || $config['trigger_mode'] === 'both') {
            $rps = getRequestsPerSecond($config);
            printf(
                "Requests/sec (%dm)   : %.1f  (on>=%.1f / off<=%.1f)\n",
                $config['req_window_minutes'], $rps,
                $config['req_threshold_on'], $config['req_threshold_off']
            );
        }
        exit(EXIT_OK);
    }

    if ($opts['force-off']) {
        setSecurityLevel($config, $config['normal_level']);
        saveState($config, ['uam_active' => false, 'changed_at' => time()]);
        logmsg($config, 'INFO', "Forced normal level: {$config['normal_level']}");
        exit(EXIT_OK);
    }

    if ($opts['force-on']) {
        setSecurityLevel($config, 'under_attack');
        saveState($config, ['uam_active' => true, 'changed_at' => time()]);
        logmsg($config, 'INFO', 'Forced Under Attack Mode.');
        exit(EXIT_OK);
    }

    // Automatic cycle.
    $mode = $config['trigger_mode'];
    if (!in_array($mode, ['load', 'requests', 'both'], true)) {
        throw new RuntimeException("Invalid trigger_mode: '{$mode}'");
    }

    // Collect one or more metrics: value + on/off thresholds + log format.
    $metrics = [];

    if ($mode === 'load' || $mode === 'both') {
        $cores       = max(1, (int)($config['cpu_cores'] ?? detectCores()));
        $la          = getLoadAverages();
        $metrics[]   = [
            'name'   => 'load/core',
            'value'  => $la[$config['load_index']] / $cores,
            'on'     => (float)$config['threshold_on'],
            'off'    => (float)$config['threshold_off'],
            'format' => '%.2f',
        ];
    }

    if ($mode === 'requests' || $mode === 'both') {
        $metrics[] = [
            'name'   => 'req/s',
            'value'  => getRequestsPerSecond($config),
            'on'     => (float)$config['req_threshold_on'],
            'off'    => (float)$config['req_threshold_off'],
            'format' => '%.1f',
        ];
    }

    // Activate if ANY metric is over its 'on' threshold; stand down only when
    // ALL metrics are below their 'off' threshold (hysteresis).
    $anyOver  = false;
    $allUnder = true;
    $desc     = [];
    foreach ($metrics as $m) {
        if ($m['value'] >= $m['on']) {
            $anyOver = true;
        }
        if ($m['value'] > $m['off']) {
            $allUnder = false;
        }
        $desc[] = sprintf(
            "%s {$m['format']} (on>={$m['format']}, off<={$m['format']})",
            $m['name'], $m['value'], $m['on'], $m['off']
        );
    }
    $descStr = implode(', ', $desc);

    $state     = loadState($config);
    $uamActive = (bool)($state['uam_active'] ?? false);
    $changedAt = (int)($state['changed_at'] ?? 0);
    $now       = time();

    if (!$uamActive && $anyOver) {
        setSecurityLevel($config, 'under_attack');
        saveState($config, ['uam_active' => true, 'changed_at' => $now]);
        logmsg($config, 'WARN', "Threshold exceeded [{$descStr}]: Under Attack Mode ON.");
    } elseif ($uamActive && $allUnder) {
        $elapsed = $now - $changedAt;
        if ($elapsed >= $config['min_uam_seconds']) {
            setSecurityLevel($config, $config['normal_level']);
            saveState($config, ['uam_active' => false, 'changed_at' => $now]);
            logmsg($config, 'INFO', "Recovered [{$descStr}]: restored level {$config['normal_level']}.");
        } else {
            logmsg($config, 'INFO', sprintf(
                'Recovered but UAM active only %ds (< %ds): waiting. [%s]',
                $elapsed, $config['min_uam_seconds'], $descStr
            ));
        }
    } else {
        logmsg($config, 'INFO', sprintf('No action (UAM=%s) [%s].', $uamActive ? 'on' : 'off', $descStr));
    }

    exit(EXIT_OK);

} catch (Throwable $e) {
    logmsg($config ?? ['log_file' => null], 'ERROR', $e->getMessage());
    exit(EXIT_RUNTIME);
}
