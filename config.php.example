<?php
/**
 * config.php — credentials and settings for vigilant
 *
 * SECURITY:
 *   - Copy this file to config.php
 *   - Restrict it:  chmod 600 config.php
 *   - Owner must be the cron user:  chown cron-user config.php
 *   - Never commit config.php (it is in .gitignore)
 *
 * Credentials are kept here, never passed as CLI arguments (those are visible
 * to other users via `ps aux` / /proc).
 */

return [
    // --- Cloudflare credentials -------------------------------------------
    // Create a SCOPED API Token (not the Global API Key):
    //   Dashboard > My Profile > API Tokens > Create Token
    // Minimum permissions (scoped to the single zone):
    //   Zone > Zone Settings > Edit   (read/write security_level)
    //   Zone > Analytics     > Read   (only for trigger_mode 'requests'/'both')
    'api_token' => 'YOUR_API_TOKEN_HERE',

    // Zone ID (Dashboard > your domain > Overview).
    'zone_id'   => 'YOUR_ZONE_ID_HERE',

    // --- Trigger mode -----------------------------------------------------
    //   'load'     -> server load average.
    //                 NOTE: on shared hosting this is the WHOLE machine's load
    //                 (all tenants), not just your site.
    //   'requests' -> requests/sec to YOUR zone (GraphQL Analytics).
    //                 Better suited to shared hosting / anti-DDoS.
    //   'both'     -> ON if either threshold is exceeded; stands down only
    //                 when BOTH are back under their 'off' threshold.
    'trigger_mode'    => 'requests',

    // --- 'load' mode ------------------------------------------------------
    'cpu_cores'       => null,   // null = auto-detect
    'load_index'      => 0,      // 0=1min, 1=5min, 2=15min
    'threshold_on'    => 1.50,   // load-per-core to switch UAM on
    'threshold_off'   => 0.70,   // load-per-core to switch UAM off (keep < on)

    // --- 'requests' mode --------------------------------------------------
    // Tip: set 'on' to ~3-5x your usual peak so legit spikes don't trip it.
    'req_threshold_on'  => 50.0, // requests/sec to switch UAM on
    'req_threshold_off' => 20.0, // requests/sec to switch UAM off (keep < on)
    'req_window_minutes' => 5,   // averaging window

    // --- Common -----------------------------------------------------------
    // Level to restore: off|essentially_off|low|medium|high
    'normal_level'    => 'medium',

    // Minimum time (seconds) UAM stays on before it may stand down.
    'min_uam_seconds' => 600,

    // Service files. On shared hosting keep them inside your home directory
    // (/var/lib, /var/log are not writable and often outside open_basedir).
    'state_file'      => __DIR__ . '/vigilant-state.json',
    'log_file'        => __DIR__ . '/vigilant.log', // null = stdout/stderr

    // HTTP timeout (seconds).
    'http_timeout'    => 15,
];
